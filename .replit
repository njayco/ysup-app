modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
[agent]
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0", "google-docs:1.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Next.js Dev Server"

[[workflows.workflow]]
name = "Next.js Dev Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'pnpm next dev --turbo -H 0.0.0.0 -p 5000 & sleep 5 && curl -s http://localhost:5000/ > /dev/null && curl -s http://localhost:5000/search > /dev/null && echo \"Pages pre-warmed\" && wait'"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["pnpm", "next-start"]
build = ["pnpm", "build"]
publicDir = "public"

[userenv]

[userenv.shared]
